# Sorta.Fit -- Environment Configuration
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# =============================================================================
# REQUIRED — Board Connection
# =============================================================================

# Which adapter to use: jira, linear, github-issues
BOARD_ADAPTER=jira

# Your board's domain (no protocol, no trailing slash)
# Jira example: mycompany.atlassian.net
# Linear example: api.linear.app
BOARD_DOMAIN=mycompany.atlassian.net

# API token for authenticating with the board
# Jira: generate at https://id.atlassian.com/manage-profile/security/api-tokens
BOARD_API_TOKEN=your-api-token-here

# The project key on your board
# Jira example: PROJ
BOARD_PROJECT_KEY=PROJ

# =============================================================================
# OPTIONAL — Board Authentication
# =============================================================================

# Email address for board authentication (required for Jira)
BOARD_EMAIL=you@example.com

# =============================================================================
# OPTIONAL — Git
# =============================================================================

# Base branch for feature branches (default: main)
GIT_BASE_BRANCH=main

# =============================================================================
# OPTIONAL — Runner Behavior
# =============================================================================

# Seconds between polling cycles (default: 3600 = 1 hour)
POLL_INTERVAL=3600

# Maximum cards to refine per cycle (default: 5)
MAX_CARDS_REFINE=5

# Maximum cards to implement per cycle (default: 2)
MAX_CARDS_CODE=2

# Maximum cards to review per cycle (default: 10)
MAX_CARDS_REVIEW=10

# Maximum cards to triage per cycle (default: 5)
MAX_CARDS_TRIAGE=5

# Maximum cards to bounce per cycle (default: 10)
MAX_CARDS_BOUNCE=10

# Comma-separated list of recipes to run in the polling loop
# Available: refine, code, review, triage
# (default: refine,code)
RECIPES_ENABLED=refine,code

# =============================================================================
# OPTIONAL — Recipe Lane Routing
# =============================================================================

# Each recipe reads cards FROM a board status and transitions them TO another.
# FROM = the status name on your board (must match exactly)
# TO = a transition key suffix (maps to TRANSITION_* in your adapter config)
# Leave TO empty to skip the transition (card stays in place).

# Refine: pick up raw cards, write specs, move to refined
RECIPE_REFINE_FROM="To Do"
RECIPE_REFINE_TO=REFINED

# Code: pick up refined cards, implement, open PR, move to review
RECIPE_CODE_FROM="Agent"
RECIPE_CODE_TO=QA

# Review: pick up cards with PRs, post review (default: don't move)
RECIPE_REVIEW_FROM="QA"
RECIPE_REVIEW_TO=

# Triage: pick up bugs, analyze, move to refined
RECIPE_TRIAGE_FROM="To Do"
RECIPE_TRIAGE_TO=REFINED

# Bounce: move rejected PRs back for rework
RECIPE_BOUNCE_FROM="QA"
RECIPE_BOUNCE_TO=AGENT

# Max times a card can bounce before escalating to a human (default: 3)
MAX_BOUNCES=3

# Where to move cards that hit the bounce limit (empty = stays in place)
# RECIPE_BOUNCE_ESCALATE=TODO
